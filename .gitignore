# =============================================================================
# .gitignore — 单-双折叠翼变体飞行器知识图谱项目
# 策略：忽略环境/缓存/备份/临时文件；保留 output/、gold/ 下的核心交付产物
# 已被 git 跟踪的文件不会被本规则忽略，如需从仓库中移除请先：
#   git rm --cached <文件路径>
# =============================================================================

# -----------------------------------------------------------------------------
# Python 字节码 / 构建产物
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

build/
dist/
wheels/
*.egg
*.egg-info/
.eggs/
pip-wheel-metadata/
share/python-wheels/
MANIFEST

# -----------------------------------------------------------------------------
# 虚拟环境
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# uv / pip / poetry 缓存（uv.lock 仍需提交，不要忽略）
.uv-cache/
.pip-cache/
.poetry/

# -----------------------------------------------------------------------------
# 测试 / 类型检查 / Lint 缓存
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

.tox/
.nox/

.mypy_cache/
.dmypy.json
dmypy.json

.ruff_cache/
.pyre/
.pytype/

# -----------------------------------------------------------------------------
# Jupyter / IPython
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# -----------------------------------------------------------------------------
# IDE / 编辑器
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.bak
*.orig
*.code-workspace

# -----------------------------------------------------------------------------
# 系统垃圾
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# 环境变量 / 密钥（避免 OPENAI_API_KEY 等被误提交）
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
secrets.json
*.pem
*.key

# -----------------------------------------------------------------------------
# Streamlit / pyvis 临时产物
# -----------------------------------------------------------------------------
.streamlit/secrets.toml
pyvis_*.html
*.pyvis.tmp.html

# -----------------------------------------------------------------------------
# 项目特有：调试 / 临时脚本（根目录约定以 _ 开头）
# -----------------------------------------------------------------------------
_tmp_*.py
_inspect*.py
_inspect_report.txt
_scratch_*.py
_debug_*.py
new.py
pipeline_test.py

# -----------------------------------------------------------------------------
# 项目特有：自动生成的备份 / 日志（保留主词典，忽略时间戳备份）
# -----------------------------------------------------------------------------
data/entities_by_type.backup_*.json
data/*.backup_*.json
data/llm_ner_expand_log.txt
data/llm_*_log.txt
data/*.tmp.json

# -----------------------------------------------------------------------------
# 项目特有：实验产物（保留正式 eval_report.txt，忽略大量探索版本）
# 注：output/ch4_*/、eval_report_ch4_*.txt 是不同实验配置的中间输出
# 若需保留，请删除下面对应行
# -----------------------------------------------------------------------------
output/ch4_g_base/
output/ch4_g_alias/
output/ch4_g_llm/
output/ch4_g_llm_full/
output/ch4_g_p0b/
output/ch4_g_v2/
output/ch4_v2/
output/eval_report_ch4_g_base.txt
output/eval_report_ch4_g_alias.txt
output/eval_report_ch4_g_llm.txt
output/eval_report_ch4_g_llm_full.txt
output/eval_report_ch4_g_p0b.txt
output/eval_report_ch4_g_v2.txt
output/eval_report_ch4_v2.txt

# 通用临时输出
*.tmp
*.temp
*.log
*.cache

# -----------------------------------------------------------------------------
# 其他
# -----------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.7z
*.rar

# Node（如果以后引入前端工具链）
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 局部覆盖（团队成员可自定义本地忽略，不入仓库）
.gitignore.local
